---
import Breadcrumb from "@/components/Breadcrumb.astro";
import HomeSidebar from "@/components/HomeSidebar.astro";
import ToolbarButton from "@/components/ToolbarButton.astro";
import { SITE } from "@/config";

type StringTitle = { pageTitle: string };
type ArrayTitle = { pageTitle: [string, string]; titleTransition: string };

type Props = (StringTitle | ArrayTitle) & {
  pageDesc?: string;
  showListToolbar?: boolean;
};

const { props } = Astro;
const { showListToolbar = true } = props;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
const isHome = Astro.url.pathname === "/";
---

<Breadcrumb />
<div class="home-desktop-grid app-layout">
  <HomeSidebar />
  <main data-backUrl={backUrl} id="main-content" class="home-main-panel">
    <section class="content-shell"
      {
        "titleTransition" in props ? (
          <h1 class="text-2xl font-semibold sm:text-3xl">
            {props.pageTitle[0]}
            <span transition:name={props.titleTransition}>{props.pageTitle[1]}</span>
          </h1>
        ) : (
          <h1 class="text-2xl font-semibold sm:text-3xl">{props.pageTitle}</h1>
        )
      }      {props.pageDesc && <p class="mt-1 text-foreground/80">{props.pageDesc}</p>}

      {
        showListToolbar && (
          <div class="content-toolbar" data-toolbar>
            <ToolbarButton href="/" selected={isHome}>最新</ToolbarButton>
            <ToolbarButton href="/posts" selected={Astro.url.pathname.startsWith("/posts")}>文章</ToolbarButton>
            <ToolbarButton href="/archives" selected={Astro.url.pathname.startsWith("/archives")}>归档</ToolbarButton>
            <ToolbarButton href="/tags" selected={Astro.url.pathname.startsWith("/tags")}>标签</ToolbarButton>
          </div>
        )
      }
      <slot />
    </section>
  </main>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent = document.querySelector("#main-content") as HTMLElement | null;
    const savedBackUrl = mainContent?.dataset?.backurl;
    if (savedBackUrl) {
      sessionStorage.setItem("backUrl", savedBackUrl);
    }

    const toolbar = document.querySelector("[data-toolbar]");
    if (!toolbar) return;

    const buttons = toolbar.querySelectorAll("[data-sort]");
    const list = document.querySelector("[data-article-list]");
    if (!list) return;

    buttons.forEach(button => {
      button.addEventListener("click", () => {
        const sortType = button.getAttribute("data-sort");
        const items = Array.from(list.children);
        items.sort((a, b) => {
          const aEl = a;
          const bEl = b;
          if (sortType === "title") {
            return (aEl.getAttribute("data-title") || "").localeCompare(
              bEl.getAttribute("data-title") || "",
              "zh-Hans-CN"
            );
          }
          return Number(bEl.getAttribute("data-ts")) - Number(aEl.getAttribute("data-ts"));
        });

        items.forEach(item => list.appendChild(item));
        buttons.forEach(btn => btn.classList.remove("is-selected"));
        button.classList.add("is-selected");
      });
    });
  });
</script>
