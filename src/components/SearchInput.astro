---
type Props = {
  action?: string;
  class?: string;
  id?: string;
  name?: string;
  placeholder?: string;
  value?: string;
};

const {
  action = "/search",
  class: className,
  id = "global-search",
  name = "q",
  placeholder = "搜索文章...",
  value = "",
} = Astro.props;
---

<form action={action} method="get" class:list={["search-input-wrap", className]}>
  <label for={id} class="sr-only">搜索文章</label>
  <input
    id={id}
    name={name}
    type="search"
    value={value}
    placeholder={placeholder}
    class="search-input"
  />
</form>
