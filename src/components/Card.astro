---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import MetaChip from "./MetaChip.astro";
import MetaRow from "./MetaRow.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, body, filePath } = Astro.props;

const { title, description, ogImage, ...props } = data;
const coverSrc = typeof ogImage === "string" ? ogImage : ogImage?.src;
const hasCover = Boolean(coverSrc);
const wordCount = (body ?? "")
  .replace(/```[\s\S]*?```/g, "")
  .replace(/`[^`]*`/g, "")
  .trim()
  .split(/\s+/)
  .filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 220));
---

<li class="home-post-card">
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block text-lg font-medium text-accent",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}

    >
      {
        hasCover ? (
          <img
            src={coverSrc}
            alt=""
            loading="lazy"
            decoding="async"
            class="article-cover"
          />
        ) : (
          <span class="article-cover-placeholder" aria-hidden="true">
            暂无封面
          </span>
        )
      }
    </a>
  </article>
</li>
