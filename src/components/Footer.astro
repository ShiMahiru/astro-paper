---
import type { HTMLAttributes } from "astro/types";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={[
    "app-layout glass-panel mt-4 rounded-3xl border-t border-border/70",
    { "sm:mt-0": noMarginTop },
    className,
  ]}
  {...attrs}
>
  <div
    class:list={[
      "py-4 sm:py-3",
      "flex justify-center",
    ]}
  >
    <div class="flex flex-col items-center text-center leading-relaxed">
      <span>
        版权所有 &#169; {currentYear}
        <a
          href="/rss.xml"
          class="ms-2 underline decoration-dashed underline-offset-4 hover:opacity-80"
          aria-label="RSS 订阅"
          title="RSS 订阅"
        >
          RSS
        </a>
      </span>
      <span>保留所有权利。</span>
    </div>
  </div>
</footer>
