---
import type { HTMLAttributes } from "astro/types";
import GlassPanel from "@/components/GlassPanel.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer class:list={["app-layout mt-10 border-t border-border/40", { "sm:mt-8": noMarginTop }, className]} {...attrs}>
  <div class="py-5 text-center text-sm text-foreground/70">
    <span>
      版权所有 &#169; {currentYear}
      <a
        href="/rss.xml"
        class="ms-2 underline decoration-dashed underline-offset-4 hover:opacity-80"
        aria-label="RSS 订阅"
        title="RSS 订阅"
      >
        RSS
      </a>
    </span>
    <span class="ms-2">保留所有权利。</span>
  </div>
</footer>
