---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={[
    "app-layout desktop-side-footer",
    { "sm:mt-auto": !noMarginTop },
    className,
  ]}
  {...attrs}
>
  <div
    class:list={[
      "desktop-side-footer-inner",
      "py-5 sm:py-4",
      "border-t border-border",
      "flex flex-col items-center justify-between gap-2 sm:flex-row-reverse sm:gap-0",
    ]}
  >
    <a
      href="https://q2.qlogo.cn/headimg_dl?dst_uin=242531778&spec=0"
      target="_blank"
      rel="noopener noreferrer"
      class="desktop-footer-avatar mb-2 inline-flex sm:order-3 sm:mb-0"
      aria-label="Mingalaba 头像"
      title="查看头像"
    >
      <img
        src="https://q2.qlogo.cn/headimg_dl?dst_uin=242531778&spec=0"
        alt="Mingalaba 头像"
        class="h-12 w-12 rounded-full border border-border object-cover sm:h-14 sm:w-14"
        loading="lazy"
        decoding="async"
      />
    </a>

    <Socials />
    <div
      class="desktop-footer-copy my-1.5 flex flex-col items-center text-center leading-relaxed"
    >
      <span>
        版权所有 &#169; {currentYear}
        <a
          href="/rss.xml"
          class="ms-2 underline decoration-dashed underline-offset-4 hover:opacity-80"
          aria-label="RSS 订阅"
          title="RSS 订阅"
        >
          RSS
        </a>
      </span>
      <span>保留所有权利。</span>
    </div>
  </div>
</footer>
