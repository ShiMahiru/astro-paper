---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";

type Props = {
  page: Page<CollectionEntry<"blog">>;
};

const { page } = Astro.props;

const ensureTrailingSlash = (url: string) =>
  url.endsWith("/") ? url : `${url}/`;

const resolveFirstPageUrl = () => {
  const candidates = [
    page.url.first,
    page.currentPage === 1 ? page.url.current : undefined,
    page.currentPage === 2 ? page.url.prev : undefined,
    page.url.current?.replace(/\/\d+\/?$/, "/"),
    page.url.prev?.replace(/\/\d+\/?$/, "/"),
    page.url.next?.replace(/\/2\/?$/, "/"),
  ];

  const firstPageUrl = candidates.find((url): url is string => Boolean(url));

  return ensureTrailingSlash(firstPageUrl ?? "/");
};

const getPageUrl = (targetPage: number) => {
  const firstPageUrl = resolveFirstPageUrl();

  if (targetPage <= 1) {
    return firstPageUrl;
  }

  if (firstPageUrl === "/") {
    return `/${targetPage}/`;
  }

  return `${firstPageUrl}${targetPage}/`;
};

const getPaginationItems = (currentPage: number, lastPage: number) => {
  if (lastPage <= 7) {
    return Array.from({ length: lastPage }, (_, index) => index + 1);
  }

  const pageSet = new Set([
    1,
    lastPage,
    currentPage,
    currentPage - 1,
    currentPage + 1,
  ]);
  const pages = Array.from(pageSet)
    .filter(pageNum => pageNum >= 1 && pageNum <= lastPage)
    .sort((a, b) => a - b);

  const items: Array<number | "ellipsis"> = [];

  for (const pageNum of pages) {
    const prevItem = items[items.length - 1];

    if (typeof prevItem === "number" && pageNum - prevItem > 1) {
      items.push("ellipsis");
    }

    items.push(pageNum);
  }

  return items;
};

const paginationItems = getPaginationItems(page.currentPage, page.lastPage);
---

{
  page.lastPage > 1 && (
    <nav
      class="my-8 flex items-center justify-center gap-2.5 sm:my-10 sm:gap-3"
      role="navigation"
      aria-label="分页导航"
    >
      <a
        href={page.url.prev as string}
        aria-label="前往上一页"
        class:list={[
          "flex h-11 w-11 items-center justify-center rounded-sm border border-white/10 bg-slate-900/90 text-slate-300 transition hover:bg-slate-800 hover:text-white sm:h-14 sm:w-14",
          { "pointer-events-none opacity-35": !page.url.prev },
        ]}
      >
        <IconChevronLeft class="h-6 w-6 sm:h-7 sm:w-7" />
      </a>

      <ul class="flex items-center gap-1.5 rounded-sm border border-white/10 bg-slate-900/90 px-1.5 py-1.5 sm:gap-2 sm:px-2 sm:py-2">
        {paginationItems.map(item => (
          <li>
            {item === "ellipsis" ? (
              <span class="flex h-11 min-w-11 items-center justify-center px-2 text-xl font-semibold text-slate-300 sm:h-14 sm:min-w-14 sm:px-3 sm:text-2xl">
                …
              </span>
            ) : (
              <a
                href={getPageUrl(item)}
                aria-label={`前往第 ${item} 页`}
                aria-current={item === page.currentPage ? "page" : undefined}
                class:list={[
                  "flex h-11 min-w-11 items-center justify-center px-2 text-xl font-semibold transition sm:h-14 sm:min-w-14 sm:px-3 sm:text-2xl",
                  item === page.currentPage
                    ? "rounded-sm bg-blue-500 text-white"
                    : "text-slate-300 hover:text-white",
                ]}
              >
                {item}
              </a>
            )}
          </li>
        ))}
      </ul>

      <a
        href={page.url.next as string}
        aria-label="前往下一页"
        class:list={[
          "flex h-11 w-11 items-center justify-center rounded-sm border border-white/10 bg-slate-900/90 text-slate-300 transition hover:bg-slate-800 hover:text-white sm:h-14 sm:w-14",
          { "pointer-events-none opacity-35": !page.url.next },
        ]}
      >
        <IconChevronRight class="h-6 w-6 sm:h-7 sm:w-7" />
      </a>
    </nav>
  )
}
