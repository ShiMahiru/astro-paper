---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";

type Props = {
  page: Page<CollectionEntry<"blog">>;
};

const { page } = Astro.props;

const ensureTrailingSlash = (url: string) =>
  url.endsWith("/") ? url : `${url}/`;

const stripPageNumber = (url: string) => url.replace(/\/(?:\d+)\/?$/, "/");

const resolveFirstPageUrl = () => {
  const candidates = [
    page.url.first,
    page.currentPage === 1 ? page.url.current : undefined,
    page.currentPage === 2 ? page.url.prev : undefined,
    page.url.current ? stripPageNumber(page.url.current) : undefined,
    page.url.prev ? stripPageNumber(page.url.prev) : undefined,
    page.url.next ? stripPageNumber(page.url.next) : undefined,
  ];

  const firstPageUrl = candidates.find((url): url is string => Boolean(url));

  return ensureTrailingSlash(firstPageUrl ?? "/");
};

const getPageUrl = (targetPage: number) => {
  const firstPageUrl = resolveFirstPageUrl();

  if (targetPage <= 1) {
    return firstPageUrl;
  }

  if (firstPageUrl === "/") {
    return `/${targetPage}/`;
  }

  return `${firstPageUrl}${targetPage}/`;
};

const getPaginationItems = (currentPage: number, lastPage: number) => {
  if (lastPage <= 7) {
    return Array.from({ length: lastPage }, (_, index) => index + 1);
  }

  const pageSet = new Set([
    1,
    lastPage,
    currentPage,
    currentPage - 1,
    currentPage + 1,
  ]);

  const pages = Array.from(pageSet)
    .filter(pageNum => pageNum >= 1 && pageNum <= lastPage)
    .sort((a, b) => a - b);

  const items: Array<number | "ellipsis"> = [];

  for (const pageNum of pages) {
    const prevItem = items[items.length - 1];

    if (typeof prevItem === "number" && pageNum - prevItem > 1) {
      items.push("ellipsis");
    }

    items.push(pageNum);
  }

  return items;
};

const paginationItems = getPaginationItems(page.currentPage, page.lastPage);

const controlBaseClass =
  "flex h-9 w-9 items-center justify-center rounded-md border border-border bg-background text-foreground transition hover:border-accent hover:text-accent sm:h-10 sm:w-10";

const disabledClass = "pointer-events-none opacity-40";
---

{
  page.lastPage > 1 && (
    <nav
      class="my-8 flex flex-col items-center gap-2 sm:my-10 sm:gap-3"
      role="navigation"
      aria-label="分页导航"
    >
      <div class="flex items-center justify-center gap-2">
        {page.url.prev ? (
          <a
            href={page.url.prev}
            aria-label="前往上一页"
            class={controlBaseClass}
          >
            <IconChevronLeft class="h-4 w-4 sm:h-5 sm:w-5" />
          </a>
        ) : (
          <span
            aria-hidden="true"
            class:list={[controlBaseClass, disabledClass]}
          >
            <IconChevronLeft class="h-4 w-4 sm:h-5 sm:w-5" />
          </span>
        )}

        <div class="rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground/80 sm:hidden">
          第 {page.currentPage} / {page.lastPage} 页
        </div>

        <ul class="hidden items-center gap-1 rounded-md border border-border bg-background p-1 sm:flex">
          {paginationItems.map(item => (
            <li>
              {item === "ellipsis" ? (
                <span class="flex h-10 min-w-8 items-center justify-center px-1 text-sm text-foreground/70">
                  …
                </span>
              ) : (
                <a
                  href={getPageUrl(item)}
                  aria-label={`前往第 ${item} 页`}
                  aria-current={item === page.currentPage ? "page" : undefined}
                  class:list={[
                    "flex h-10 min-w-10 items-center justify-center rounded-md px-2 text-sm font-medium transition",
                    item === page.currentPage
                      ? "bg-accent text-background"
                      : "text-foreground/80 hover:text-accent",
                  ]}
                >
                  {item}
                </a>
              )}
            </li>
          ))}
        </ul>

        {page.url.next ? (
          <a
            href={page.url.next}
            aria-label="前往下一页"
            class={controlBaseClass}
          >
            <IconChevronRight class="h-4 w-4 sm:h-5 sm:w-5" />
          </a>
        ) : (
          <span
            aria-hidden="true"
            class:list={[controlBaseClass, disabledClass]}
          >
            <IconChevronRight class="h-4 w-4 sm:h-5 sm:w-5" />
          </span>
        )}
      </div>
    </nav>
  )
}
