---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";

type Props = {
  page: Pick<Page<CollectionEntry<"blog">>, "currentPage" | "lastPage" | "url">;
};

const { page } = Astro.props;

const ensureTrailingSlash = (url: string) => (url.endsWith("/") ? url : `${url}/`);
const stripPageNumber = (url: string) => url.replace(/\/(?:\d+)\/?$/, "/");

const resolveFirstPageUrl = () => {
  const candidates = [
    page.url.first,
    page.currentPage === 1 ? page.url.current : undefined,
    page.currentPage === 2 ? page.url.prev : undefined,
    page.url.current ? stripPageNumber(page.url.current) : undefined,
    page.url.prev ? stripPageNumber(page.url.prev) : undefined,
    page.url.next ? stripPageNumber(page.url.next) : undefined,
  ];
  const firstPageUrl = candidates.find((url): url is string => Boolean(url));
  return ensureTrailingSlash(firstPageUrl ?? "/");
};

const getPageUrl = (targetPage: number) => {
  const firstPageUrl = resolveFirstPageUrl();
  if (targetPage <= 1) return firstPageUrl;
  if (firstPageUrl === "/") return `/${targetPage}/`;
  return `${firstPageUrl}${targetPage}/`;
};

const getPaginationItems = (currentPage: number, lastPage: number) => {
  if (lastPage <= 7) return Array.from({ length: lastPage }, (_, index) => index + 1);
  const pageSet = new Set([1, lastPage, currentPage, currentPage - 1, currentPage + 1]);
  const pages = Array.from(pageSet)
    .filter(pageNum => pageNum >= 1 && pageNum <= lastPage)
    .sort((a, b) => a - b);

  const items: Array<number | "ellipsis"> = [];
  for (const pageNum of pages) {
    const prevItem = items[items.length - 1];
    if (typeof prevItem === "number" && pageNum - prevItem > 1) items.push("ellipsis");
    items.push(pageNum);
  }
  return items;
};

const paginationItems = getPaginationItems(page.currentPage, page.lastPage);
---

{
  page.lastPage > 1 && (
    <nav class="pagination-shell" role="navigation" aria-label="分页导航">
      {page.url.prev ? (
        <a href={page.url.prev} aria-label="前往上一页" class="pagination-control">
          <IconChevronLeft class="h-4 w-4" />
        </a>
      ) : (
        <span aria-hidden="true" class="pagination-control is-disabled">
          <IconChevronLeft class="h-4 w-4" />
        </span>
      )}

      <div class="pagination-compact sm:hidden">第 {page.currentPage} / {page.lastPage} 页</div>

      <ul class="hidden items-center gap-1 sm:flex">
        {paginationItems.map(item => (
          <li>
            {item === "ellipsis" ? (
              <span class="pagination-ellipsis">…</span>
            ) : (
              <a
                href={getPageUrl(item)}
                aria-label={`前往第 ${item} 页`}
                aria-current={item === page.currentPage ? "page" : undefined}
                class:list={["pagination-control", { "is-selected": item === page.currentPage }]}
              >
                {item}
              </a>
            )}
          </li>
        ))}
      </ul>

      {page.url.next ? (
        <a href={page.url.next} aria-label="前往下一页" class="pagination-control">
          <IconChevronRight class="h-4 w-4" />
        </a>
      ) : (
        <span aria-hidden="true" class="pagination-control is-disabled">
          <IconChevronRight class="h-4 w-4" />
        </span>
      )}
    </nav>
  )
}
