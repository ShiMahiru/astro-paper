---
import { GISCUS } from "@/config";

const giscusTheme =
  Astro.cookies.get("theme")?.value === "dark"
    ? "dark"
    : "preferred_color_scheme";
---

{
  GISCUS.enabled && (
    <section class="mt-10" aria-label="评论区">
      <h2 class="mb-4 text-lg font-semibold">评论</h2>
      <div id="giscus-container"></div>
    </section>
  )
}

<script
  is:inline
  define:vars={{
    giscusConfig: {
      repo: GISCUS.repo,
      repoId: GISCUS.repoId,
      category: GISCUS.category,
      categoryId: GISCUS.categoryId,
      mapping: GISCUS.mapping,
      strict: GISCUS.strict,
      reactionsEnabled: GISCUS.reactionsEnabled,
      emitMetadata: GISCUS.emitMetadata,
      inputPosition: GISCUS.inputPosition,
      theme: giscusTheme,
      lang: GISCUS.lang,
      loading: GISCUS.loading,
    },
  }}
>
  const setGiscusTheme = () => {
    const theme =
      document.documentElement.getAttribute("data-theme") === "dark"
        ? "dark"
        : "light";

    const giscusFrame = document.querySelector("iframe.giscus-frame");

    if (!giscusFrame?.contentWindow) return;

    giscusFrame.contentWindow.postMessage(
      {
        giscus: {
          setConfig: {
            theme,
          },
        },
      },
      "https://giscus.app"
    );
  };

  const loadGiscus = () => {
    const container = document.querySelector("#giscus-container");
    if (!container) return;

    const hasFrame = container.querySelector("iframe.giscus-frame");
    const hasPendingScript = container.querySelector("script[data-giscus]");

    if (hasFrame || hasPendingScript) return;

    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.async = true;
    script.crossOrigin = "anonymous";
    script.setAttribute("data-giscus", "true");
    script.setAttribute("data-repo", giscusConfig.repo);
    script.setAttribute("data-repo-id", giscusConfig.repoId);
    script.setAttribute("data-category", giscusConfig.category);
    script.setAttribute("data-category-id", giscusConfig.categoryId);
    script.setAttribute("data-mapping", giscusConfig.mapping);
    script.setAttribute("data-strict", giscusConfig.strict);
    script.setAttribute(
      "data-reactions-enabled",
      String(giscusConfig.reactionsEnabled)
    );
    script.setAttribute("data-emit-metadata", String(giscusConfig.emitMetadata));
    script.setAttribute("data-input-position", giscusConfig.inputPosition);
    script.setAttribute("data-theme", giscusConfig.theme);
    script.setAttribute("data-lang", giscusConfig.lang);
    script.setAttribute("data-loading", giscusConfig.loading);

    container.appendChild(script);
  };

  const initGiscus = () => {
    loadGiscus();
    setGiscusTheme();
  };

  const setupThemeSync = () => {
    const themeBtn = document.querySelector("#theme-btn");
    if (!themeBtn || themeBtn.dataset.giscusThemeBound === "true") return;

    themeBtn.addEventListener("click", () => {
      window.setTimeout(setGiscusTheme, 0);
    });
    themeBtn.dataset.giscusThemeBound = "true";
  };

  initGiscus();
  setupThemeSync();
  document.addEventListener("astro:after-swap", () => {
    initGiscus();
    setupThemeSync();
  });
</script>
