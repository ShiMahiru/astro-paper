---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import ToolbarButton from "@/components/ToolbarButton.astro";
import SearchInput from "@/components/SearchInput.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-6 -top-full z-50 px-3 py-2 text-accent transition-all focus:top-4"
>
  跳转到正文
</a>

<header
  class="home-header flex app-layout flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "border-b border-border/70 py-3 sm:py-4 md:py-5",
      "home-header-inner relative w-full",
      "px-0",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href="/"
      class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}
    </a>

    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline self-end p-2 sm:hidden"
        aria-label="打开菜单"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>

      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-full grid-cols-2 place-content-center gap-2 border-y border-border/70 py-2 sm:mt-0 sm:w-auto sm:border-0 sm:py-0",
          "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
          "hidden",
          "sm:flex sm:items-center sm:gap-x-5 sm:gap-y-0",
        ]}
      >
        <li class="col-span-2">
          <a href="/" class:list={{ "active-nav": currentPath === "/" }}>
            首页
          </a>
        </li>
        <li class="col-span-2">
          <a href="/about" class:list={{ "active-nav": isActive("/about") }}>
            关于
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href="/archives"
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1",
                  {
                    "active-nav": isActive("/archives"),
                  },
                ]}
                title="归档"
                aria-label="归档"
              >
                <span>归档</span>
              </LinkButton>
            </li>
          )
        }

        <li class="col-span-2 hidden sm:block">
          <form action="/search" method="get">
            <label for="desktop-search" class="sr-only">搜索</label>
            <input
              id="desktop-search"
              type="search"
              name="q"
              placeholder="搜索文章..."
              class="w-44 border-b border-border/70 px-0 py-1.5 text-sm text-foreground focus:outline-none"
            />
          </form>
        </li>

        <li class="col-span-1 flex items-center justify-center sm:hidden">
          <LinkButton
            href="/search"
            class:list={[
              "focus-outline flex p-3 sm:p-1",
              { "[&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="搜索"
            aria-label="搜索"

          >
            <IconMoon class="theme-icon scale-100 rotate-0 dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="theme-icon scale-0 rotate-90 dark:scale-100 dark:rotate-0" />
          </button>
        )}
        <button
          id="menu-btn"
          class="toolbar-icon-btn sm:hidden"
          aria-label="打开菜单"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <IconX id="close-icon" class="hidden size-5" />
          <IconMenuDeep id="menu-icon" class="size-5" />
        </button>
      </div>
    </div>

    <div class="topbar-nav-desktop">
      <nav class="topbar-nav" aria-label="主导航">
        <ToolbarButton href="/" selected={currentPath === "/"}>首页</ToolbarButton>
        <ToolbarButton href="/posts" selected={isActive("/posts")}>文章</ToolbarButton>
        <ToolbarButton href="/tags" selected={isActive("/tags")}>标签</ToolbarButton>
        {SITE.showArchives && (
          <ToolbarButton href="/archives" selected={isActive("/archives")}>归档</ToolbarButton>
        )}
        <ToolbarButton href="/about" selected={isActive("/about")}>关于</ToolbarButton>
      </nav>
      <SearchInput id="desktop-search" />
    </div>

    <div id="menu-items" class="mobile-menu hidden" aria-label="主导航">
      <nav class="mobile-menu-links">
        <ToolbarButton href="/" selected={currentPath === "/"}>首页</ToolbarButton>
        <ToolbarButton href="/posts" selected={isActive("/posts")}>文章</ToolbarButton>
        <ToolbarButton href="/tags" selected={isActive("/tags")}>标签</ToolbarButton>
        {SITE.showArchives && (
          <ToolbarButton href="/archives" selected={isActive("/archives")}>归档</ToolbarButton>
        )}
        <ToolbarButton href="/about" selected={isActive("/about")}>关于</ToolbarButton>
      </nav>
      <SearchInput id="mobile-search" />
    </div>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn") as HTMLButtonElement | null;
    const menuItems = document.querySelector("#menu-items") as HTMLElement | null;
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "打开菜单" : "关闭菜单");
      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>
