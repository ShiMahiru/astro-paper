---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconX from "@/assets/icons/IconX.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  跳转到正文
</a>

<header
  class="home-header app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "home-header-inner relative w-full bg-background",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href="/"
      class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}
    </a>
    <nav
      id="nav-menu"
      class="flex w-full items-center justify-end sm:ms-2 sm:space-x-3 sm:py-0"
    >
      <form
        action="/search"
        method="get"
        class="relative me-2 hidden w-full max-w-64 sm:block"
      >
        <label for="header-search" class="sr-only">搜索</label>
        <IconSearch class="pointer-events-none absolute top-1/2 left-3 size-4 -translate-y-1/2 opacity-70" />
        <input
          id="header-search"
          name="q"
          type="search"
          placeholder="搜索"
          class="focus-outline w-full rounded-xl border border-border bg-card py-2 pr-3 pl-9 text-sm placeholder:text-muted"
        />
      </form>
      <button
        id="menu-btn"
        class="focus-outline rounded-xl border border-border bg-card p-2 sm:hidden"
        aria-label="打开菜单栏"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconMenuDeep id="menu-icon-open" />
        <IconX id="menu-icon-close" class="hidden" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "absolute top-full right-0 z-50 mt-2 flex min-w-40 flex-col gap-1 rounded-xl border border-border bg-background/95 p-2 shadow-lg backdrop-blur",
          "[&>li>a]:hover:bg-card [&>li>a]:block [&>li>a]:rounded-lg [&>li>a]:px-4 [&>li>a]:py-2.5 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:whitespace-nowrap [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1 sm:[&>li>a]:hover:bg-transparent",
          "hidden",
          "sm:static sm:z-auto sm:mt-0 sm:flex sm:w-auto sm:flex-row sm:items-center sm:gap-x-5 sm:gap-y-0 sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none sm:backdrop-blur-none",
        ]}
      >
        <li>
          <a href="/" class:list={{ "active-nav": isActive("/") }}> 首页 </a>
        </li>
        <li>
          <a href="/about" class:list={{ "active-nav": isActive("/about") }}>
            关于
          </a>
        </li>
        {
          SITE.showArchives && (
            <li>
              <LinkButton
                href="/archives"
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1",
                  {
                    "active-nav": isActive("/archives"),
                  },
                ]}
                title="归档"
                aria-label="归档"
              >
                <span>归档</span>
              </LinkButton>
            </li>
          )
        }
        {
          SITE.lightAndDarkMode && (
            <li class="flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline relative size-12 p-4 sm:size-8 hover:[&>svg]:stroke-accent"
                title="切换浅色/深色模式"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const MOBILE_BREAKPOINT = 640;

  function syncNavByViewport() {
    const menuBtn = document.querySelector<HTMLButtonElement>("#menu-btn");
    const menuItems = document.querySelector<HTMLUListElement>("#menu-items");
    const menuIconOpen = document.querySelector<SVGElement>("#menu-icon-open");
    const menuIconClose = document.querySelector<SVGElement>("#menu-icon-close");

    if (!menuBtn || !menuItems || !menuIconOpen || !menuIconClose) return;

    const isDesktopView = window.innerWidth >= MOBILE_BREAKPOINT;

    if (isDesktopView) {
      menuBtn.setAttribute("aria-expanded", "false");
      menuBtn.setAttribute("aria-label", "打开菜单栏");
      menuItems.classList.remove("hidden");
      menuIconOpen.classList.remove("hidden");
      menuIconClose.classList.add("hidden");
      return;
    }

    const isOpen = menuBtn.getAttribute("aria-expanded") === "true";

    menuItems.classList.toggle("hidden", !isOpen);
    menuIconOpen.classList.toggle("hidden", isOpen);
    menuIconClose.classList.toggle("hidden", !isOpen);
  }

  function toggleNav() {
    const menuBtn = document.querySelector<HTMLButtonElement>("#menu-btn");
    const menuItems = document.querySelector<HTMLUListElement>("#menu-items");
    const menuIconOpen = document.querySelector<SVGElement>("#menu-icon-open");
    const menuIconClose = document.querySelector<SVGElement>("#menu-icon-close");

    if (!menuBtn || !menuItems || !menuIconOpen || !menuIconClose) return;

    if (menuBtn.dataset.bound === "true") {
      syncNavByViewport();
      return;
    }

    menuBtn.dataset.bound = "true";

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute(
        "aria-label",
        openMenu ? "打开菜单栏" : "关闭菜单栏"
      );

      syncNavByViewport();
    });

    document.addEventListener("click", event => {
      if (window.innerWidth >= MOBILE_BREAKPOINT) return;
      const target = event.target as Node;
      if (menuBtn.contains(target) || menuItems.contains(target)) return;
      menuBtn.setAttribute("aria-expanded", "false");
      menuBtn.setAttribute("aria-label", "打开菜单栏");
      syncNavByViewport();
    });

    menuItems.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => {
        if (window.innerWidth >= MOBILE_BREAKPOINT) return;
        menuBtn.setAttribute("aria-expanded", "false");
        menuBtn.setAttribute("aria-label", "打开菜单栏");
        syncNavByViewport();
      });
    });

    syncNavByViewport();
  }

  toggleNav();
  window.addEventListener("resize", syncNavByViewport);

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", () => {
    toggleNav();
    syncNavByViewport();
  });
</script>
